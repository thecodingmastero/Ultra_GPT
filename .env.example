# Backend variables
SECRET_KEY=replace-me
JWT_SECRET_KEY=replace-me
# SQLite for local dev; set a Render Postgres URL in production:
DATABASE_URL=sqlite:///instance/better_investor.db
AI_PROVIDER=stub
MARKET_DATA_PROVIDER=finnhub
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini
FINNHUB_API_KEY=replace-me

# Frontend variables (also set in frontend/.env)
# Replace with your Render backend URL in production:
VITE_API_BASE_URL=http://127.0.0.1:5000
